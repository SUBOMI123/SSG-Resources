# Database (Local Development)
# For local development with docker-compose:
DATABASE_URL="postgresql://ssg_user:ssg_password@localhost:5432/ssg_dev"

# Environment
NODE_ENV="development"

# Customer checkout
# BUSINESS_WHATSAPP_NUMBER="+2348000000000"

# Paystack (Phase 2)
# PAYSTACK_SECRET_KEY="pk_test_..." (add in Vercel, not here)
# PAYSTACK_PUBLIC_KEY="pk_test_..."

# Admin auth
# ADMIN_AUTH_SECRET="..." (add in Vercel, not here)

# Future: Sentry (Phase 1)
# SENTRY_DSN="..."
# Production (Vercel + Supabase)
# Set in Vercel Dashboard > Settings > Environment Variables:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# Paystack (Phase 2)
# Set in Vercel Dashboard as:
# PAYSTACK_SECRET_KEY="sk_live_..." (do NOT put in git)
# PAYSTACK_PUBLIC_KEY="pk_live_..."

# Admin auth
# ADMIN_AUTH_SECRET="..." (generate with: openssl rand -base64 32)

# Sentry (Phase 1)
# SENTRY_DSN="https://...@sentry.io/..."
